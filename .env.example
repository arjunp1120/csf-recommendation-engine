APP_ENV=local
APP_NAME=csf-recommendation-engine
APP_DEBUG=true
APP_TIMEZONE=America/New_York

DATABASE_URL=postgresql://user:password@localhost:5432/csf

CHAMPION_MODEL_PATH=src/csf_recommendation_engine/scripts/proxy_model_live.pkl
MODEL_ARTIFACTS_PATH=src/csf_recommendation_engine/scripts/proxy_model_artifacts.pkl

# Heuristics artifacts (local disk)
HEURISTICS_ARTIFACT_DIR=src/data/heuristics
HEURISTICS_ENTITY_FEATURES_LATEST_FILENAME=entity_features_latest.parquet
HEURISTICS_INSTRUMENT_FEATURES_LATEST_FILENAME=instrument_features_latest.parquet
HEURISTICS_ACTIVE_VENUE_LOOKBACK_DAYS=30
HEURISTICS_HISTORY_DAYS=365

# Comma-separated list of completed trade statuses in trade_history
HEURISTICS_COMPLETED_STATUSES=Filled,Calculated,Done for Day,Pending Clearing

# Reranking controls
RERANK_ENABLED=true
RERANK_REQUIRE_HEURISTICS=false
RERANK_CANDIDATE_POOL_SIZE=200
RERANK_WEIGHT_LIGHTFM=1.0
RERANK_WEIGHT_TIME_AFFINITY=0.1
RERANK_WEIGHT_RECENCY=0.1
RERANK_WEIGHT_SIZE_FIT=0.1
RERANK_RECENCY_HALFLIFE_DAYS=30.0

# Nightly pipeline
NIGHTLY_PIPELINE_ENABLED=true
NIGHTLY_SCHEDULE_CRON=0 2 * * *
NIGHTLY_SCHEDULE_TIMEZONE=America/New_York
NIGHTLY_MIN_WORKING_QUANTITY=5
NIGHTLY_TOP_K=3
NIGHTLY_BATCH_SIZE=25
NIGHTLY_MAX_CONCURRENCY=2
CROSS_MATCH_THRESHOLD=0.6
REC_REFRESH_ENABLED=true

EXTRACTION_MIN_ROWS=1
EXTRACTION_NULL_THRESHOLD=0.05

# DAF / LLM (existing)
DAF_BASE_URL=https://daf-sdk-backend.azurewebsites.net
DAF_API_KEY=
DAF_AGENT_DIRECT_API_KEY=
RECOMMENDATION_AGENT_ID=
LLM_API_KEY=
LLM_MODEL_NAME=gpt-4o
LLM_MODEL_PROVIDER=OpenAI
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=4096
LLM_ENABLED=true
LLM_CANDIDATE_POOL_SIZE=10
LLM_REQUEST_TIMEOUT_S=60

# Externally configured DAF agent / swarm IDs (Intelligence Engine v1)
# DAF_TAGGER_AGENT_ID has a working default for the existing IOI tagger.
# Other swarm IDs are filled in as the swarms are configured on the DAF platform.
DAF_TAGGER_AGENT_ID=b78ee6e0-9cd8-40ea-98bc-77bf442f60e9
DAF_PROFILER_SWARM_ID=
DAF_MARKET_READER_SWARM_ID=
DAF_RECOMMENDER_EXPLAINER_SWARM_ID=
DAF_MATCH_STRATEGIST_SWARM_ID=
DAF_COVERAGE_COACH_SWARM_ID=

# Embedding provider settings: DEFERRED for v1 (pgvector unavailable on local DB).
# When enabled: EMBEDDING_PROVIDER, EMBEDDING_MODEL, EMBEDDING_DIMENSION.

# Critic / validator (plan §11.4)
CRITIC_MODE=shadow
CRITIC_PROMOTION_VIOLATION_RATE=0.01
CRITIC_PROMOTION_WINDOW=500

# Voice inquiry / Match Universe Cache (plan §10, §17)
VOICE_INQUIRY_EXPIRY_MINUTES=240
MATCH_UNIVERSE_REBUILD_INTERVAL_SECONDS=300
MATCH_QTY_OVERLAP_RATIO=0.5
MATCH_PRICE_TOLERANCE_BPS=25
MATCH_PRICE_TOLERANCE_INDICATION_BPS=50

# Match dedup windows (plan §10.2)
MATCH_DEDUP_WINDOW_HOURS=24
MATCH_FEEDBACK_DEDUP_WINDOW_HOURS=168

# IOI back-stop polling job (plan §13.2, Step 4.6)
IOI_PROCESSING_POLLING_INTERVAL_SECONDS_MARKET=120
IOI_PROCESSING_POLLING_INTERVAL_SECONDS_OFF_HOURS=1800
IOI_PROCESSING_GRACE_SECONDS=30
IOI_PROCESSING_MAX_ATTEMPTS=3

# Dossier "hot" thresholds (plan §17)
DOSSIER_HOT_TRADE_HOURS=24
DOSSIER_HOT_INQUIRY_HOURS=4

# Correlative-attribution job (plan §14.5)
CORRELATIVE_ATTRIBUTION_WINDOW_HOURS=24

# Reranker: flow polarity penalty weight (plan Step 1.8). Default 0 = disabled.
RERANK_WEIGHT_FLOW_POLARITY=0.0
